WEB_PORT=5177
# Docker container -> host-published YouChat backend.
YOUCHAT_API_BASE=http://host.docker.internal:18080/api

# Optional AI overrides. Usually leave empty and use config/ai-providers.json.
YOUCHAT_AI_BASE=
YOUCHAT_AI_MODEL=

# Optional database repair helper override.
YOUCHAT_MYSQL_CONNECTION_STRING=

# Auto-check the YouChat backend database mode and restore MySQL if it falls back to SQLite.
YOUCHAT_DATABASE_GUARD_ENABLED=1
YOUCHAT_DATABASE_GUARD_INTERVAL_MS=300000
YOUCHAT_DATABASE_GUARD_MIN_HISTORY_COUNT=1000

# Optional PromptWorks sidecar import target.
PROMPTWORKS_API_BASE=http://host.docker.internal:5188/api/v1
PROMPTWORKS_TIMEOUT_MS=60000
