{
  "name": "youchat-dev-web",
  "version": "0.1.0",
  "private": true,
  "description": "Secondary-development web workbench for YouChat.",
  "scripts": {
    "dev": "node server.js",
    "check": "node --check server.js && node --check public/app.js",
    "patch:export": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/export-devkit-patch.ps1",
    "client:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/audit-client-update.ps1",
    "client:audit:compare": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/compare-client-audits.ps1",
    "fnos:health": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/check-fnos-youchat-health.ps1",
    "fnos:restore:mysql": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/restore-fnos-mysql-mode.ps1"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0"
  }
}
